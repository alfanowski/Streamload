# Streamload v2 environment variables

# ── Production secrets ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=change-me-strong-random-secret

# ── Docker image versions ─────────────────────────────────────────────────────
# Pin to a specific release, or leave commented to use :latest
# STREAMLOAD_VERSION=v0.2.0
# STREAMLOAD_WEB_VERSION=v0.2.0

# ── Network bind ──────────────────────────────────────────────────────────────
# Caddy host bind. Change to your Tailscale IP for production:
#   BIND_HOST=$(tailscale ip -4)
# Leave as 0.0.0.0 if Tailscale ACLs already gate external access.
# BIND_HOST=100.x.y.z

# ── Database (local dev only — production uses compose env override) ──────────
DATABASE_URL=postgresql+asyncpg://streamload:streamload@127.0.0.1:5432/streamload
DATABASE_URL_TEST=postgresql+asyncpg://streamload:streamload@127.0.0.1:5432/streamload_test

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Put your real Resend key here, NEVER commit .env
RESEND_API_KEY=re_REPLACE_ME

# ── TMDB ──────────────────────────────────────────────────────────────────────
TMDB_API_KEY=REPLACE_ME

# ── WebAuthn relying-party identity ──────────────────────────────────────────
# For production, set to your Tailscale MagicDNS hostname
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Streamload
WEBAUTHN_ORIGIN=http://localhost:8000
# WEBAUTHN_RP_ID=streamload.YOUR-TAILNET.ts.net
# WEBAUTHN_ORIGIN=https://streamload.YOUR-TAILNET.ts.net

# ── Server bind (dev) ─────────────────────────────────────────────────────────
STREAMLOAD_API_HOST=127.0.0.1
STREAMLOAD_API_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
STREAMLOAD_LOG_LEVEL=INFO
