    "download": {
        "thread_count": 8,
        "retry_count": 25,
        "max_concurrent": 3,
        "max_speed": null,
        "cleanup_tmp": true
    },
    "process": {
        "use_gpu": false,
        "generate_nfo": false,
        "merge_audio": true,
        "merge_subtitle": true,
        "subtitle_format": "auto"
    },
    "network": {
        "timeout": 30,
        "max_retry": 8,
        "verify_ssl": true,
        "proxy": null
    },
