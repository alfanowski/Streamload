    "preferred_subtitle": "auto",
    "auto_update": true,
    "output": {
        "root_path": "Video",
        "movie_folder": "Movie",
        "serie_folder": "Serie",
        "anime_folder": "Anime",
        "movie_format": "{title} ({year})",
        "episode_format": "{series}/S{season:02d}/{title} S{season:02d}E{episode:02d}",
        "extension": "mkv"
